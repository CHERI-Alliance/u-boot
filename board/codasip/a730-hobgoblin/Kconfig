if TARGET_CODASIP_A730_HOBGOBLIN || TARGET_CODASIP_A730_HOBGOBLIN_PROFPGA

config SYS_BOARD
	default "a730-hobgoblin"

config SYS_VENDOR
	default "codasip"

config SYS_CPU
	default "generic"

config SYS_CONFIG_NAME
	default "codasip-a730-hobgoblin"

config TEXT_BASE
	default 0x2000000000 if TARGET_CODASIP_A730_HOBGOBLIN_PROFPGA && !RISCV_SMODE
	default 0x2000200000 if TARGET_CODASIP_A730_HOBGOBLIN_PROFPGA && RISCV_SMODE
	default 0x80000000 if TARGET_CODASIP_A730_HOBGOBLIN && !RISCV_SMODE
	default 0x80200000 if TARGET_CODASIP_A730_HOBGOBLIN && RISCV_SMODE

config BOARD_SPECIFIC_OPTIONS # dummy
	def_bool y
	select GENERIC_RISCV
	imply MMC
	imply SPI
	imply MMC_SPI
	imply XILINX_GPIO
	imply GPIO_HOG

endif
